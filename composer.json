{
  "name": "bitstrange/wp-membership-registration-plugin",
  "description": "WordPress membership registration plugin with PDF generation",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "tecnickcom/tcpdf": "^6.11"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.8",
    "wp-coding-standards/wpcs": "^3.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpunit/phpunit": "^9.6",
    "brain/monkey": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "WpMembershipRegistration\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "vendor-dir": "vendor",
    "optimize-autoloader": true
  },
  "extra": {
    "strauss": {
      "target_directory": "vendor-prefixed",
      "namespace_prefix": "WpMembershipRegistration\\Vendor\\",
      "classmap_prefix": "WpMembershipRegistration_Vendor_",
      "packages": [
        "tecnickcom/tcpdf"
      ],
      "delete_vendor_files": false
    }
  },
  "scripts": {
    "phpcs": "phpcs --standard=.phpcs.xml src/ wp-membership-registration.php",
    "phpunit": "phpunit",
    "prefix-namespaces": [
      "sh -c 'test -f ./bin/strauss.phar || (mkdir -p bin && curl -o bin/strauss.phar -L -C - https://github.com/BrianHenryIE/strauss/releases/latest/download/strauss.phar)'",
      "@php bin/strauss.phar",
      "@php bin/patch-vendor-prefixed.php",
      "@composer dump-autoload"
    ],
    "post-install-cmd": ["@prefix-namespaces"],
    "post-update-cmd": ["@prefix-namespaces"]
  }
}
