#: templates/admin-settings-page.php:268
msgid "Consent checkbox text"
msgstr "Text der Zustimmungs-Checkbox"

#: templates/admin-settings-page.php:274
msgid "Label for the GDPR consent checkbox on the registration form. Required for submission."
msgstr "Bezeichnung für die DSGVO-Zustimmungs-Checkbox im Anmeldeformular. Für die Einreichung erforderlich."

#: templates/admin-settings-page.php:279
msgid "Success message"
msgstr "Erfolgsmeldung"

#: templates/admin-settings-page.php:285
msgid "Message shown in-place after a successful form submission."
msgstr "Meldung, die nach einer erfolgreichen Formulareinreichung angezeigt wird."

#: templates/admin-settings-page.php:290
msgid "Offer direct download link"
msgstr "Direkten Download-Link anbieten"

#: templates/admin-settings-page.php:300
msgid "When enabled, the success screen shows a link for the member to download their pre-filled PDF immediately."
msgstr "Wenn aktiviert, zeigt die Erfolgsseite einen Link, über den das Mitglied das vorausgefüllte PDF sofort herunterladen kann."

#: templates/admin-settings-page.php:305
msgid "Fallback Language"
msgstr "Ausweichsprache"

#: templates/admin-settings-page.php:310
